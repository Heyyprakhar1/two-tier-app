pipeline {
    agent any
    
    stages {
        stage("Code Clone") {
            steps {
                git url: "https://github.com/Heyyprakhar1/two-tier-app.git", branch: "project"
                echo "Code cloned successfully..!"
            }
        }
        
        stage("Trivy Scan") {
            steps {
                sh "trivy fs . -o results.json"
                echo "Security scan completed"
            }
        }
        
        stage("Docker Build") {
            steps {
                sh "docker build -t my-app ."
                echo "Docker build successfully..!"
            }
        }
        
        stage("DockerHub Push") {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhubcred',
                    usernameVariable: 'DockerHubUser',
                    passwordVariable: 'DockerHubPass'
                )]) {
                    sh '''
                      echo "$DockerHubPass" | docker login -u "$DockerHubUser" --password-stdin
                      docker tag my-app $DockerHubUser/my-app:latest
                      docker push $DockerHubUser/my-app:latest
                    '''
                }
            }
        }
        
        // ⭐ THIS IS THE CRITICAL STAGE - ALL CHANGES HERE! ⭐
        stage("Deploy Application") {
            steps {
                echo 'Deploying application...'
                sh """
                    # ✅ FIX 1: Stop containers but KEEP volumes (removed -v flag)
                    docker compose down || true
                    
                    # ✅ FIX 2: Start MySQL first
                    echo 'Starting MySQL database...'
                    docker compose up -d mysql
                    
                    # ✅ FIX 3: Wait for MySQL to be ready (CRITICAL!)
                    echo 'Waiting for MySQL to initialize (40 seconds)...'
                    sleep 40
                    
                    # ✅ FIX 4: Verify MySQL is accessible
                    docker exec mysql mysqladmin ping -h localhost -u root -proot || exit 1
                    
                    # ✅ FIX 5: Ensure todos table exists
                    echo 'Checking if todos table exists...'
                    if ! docker exec mysql mysql -u admin -padmin mydb -e "SHOW TABLES;" | grep -q "todos"; then
                        echo 'Table missing! Creating from schema.sql...'
                        docker exec -i mysql mysql -u admin -padmin mydb < schema.sql
                    else
                        echo 'Table exists, skipping creation'
                    fi
                    
                    # ✅ FIX 6: Now start Flask app
                    echo 'Starting Flask application...'
                    docker compose up -d flask-app
                    
                    # ✅ FIX 7: Wait for Flask to be ready
                    echo 'Waiting for Flask app to start (15 seconds)...'
                    sleep 15
                    
                    # ✅ FIX 8: Health check with retries
                    echo 'Running health checks...'
                    for i in {1..10}; do
                        if curl -f http://localhost:5000/health; then
                            echo 'Application is healthy!'
                            exit 0
                        fi
                        echo "Health check attempt \$i/10 failed, retrying..."
                        sleep 3
                    done
                    
                    # If we get here, health check failed
                    echo 'Health check failed after 10 attempts!'
                    echo 'Flask logs:'
                    docker compose logs flask-app
                    exit 1
                """
            }
        }
        
        // ✅ FIX 9: Add verification stage
        stage("Verify Deployment") {
            steps {
                echo 'Verifying deployment...'
                sh """
                    echo '=== Container Status ==='
                    docker compose ps
                    
                    echo '=== Database Tables ==='
                    docker exec mysql mysql -u admin -padmin mydb -e "SHOW TABLES;"
                    
                    echo '=== Sample Data Count ==='
                    docker exec mysql mysql -u admin -padmin mydb -e "SELECT COUNT(*) as total FROM todos;" || true
                    
                    echo '=== Application Health ==='
                    curl -s http://localhost:5000/health | python3 -m json.tool || true
                """
            }
        }
    }
    
    post {
        always {
            echo 'Cleaning up...'
            sh 'docker logout || true'
        }
        
        success {
            echo 'Pipeline succeeded! 🎉'
            emailext(
                from: 'heyyprakhar0106@gmail.com',
                to: 'heyyprakhar0106@gmail.com',
                subject: '✅ Build Success - Two-Tier App',
                body: """
                    Build completed successfully!
                    
                    Application is running at: http://localhost:5000
                    
                    Container Status:
                    ${sh(script: 'docker compose ps', returnStdout: true)}
                """
            )
        }
        
        failure {
            echo 'Pipeline failed! ❌'
            emailext(
                from: 'heyyprakhar0106@gmail.com',
                to: 'heyyprakhar0106@gmail.com',
                subject: '❌ Build Failed - Two-Tier App',
                body: """
                    Build failed!
                    
                    Check Jenkins console output for details.
                    
                    Recent Logs:
                    ${sh(script: 'docker compose logs --tail=50 || echo "No logs available"', returnStdout: true)}
                """
            )
        }
    }
}
